# ── LocalStack (local development) ────────────────────────────────────────
# Set USE_LOCALSTACK=true to route all AWS SDK calls to LocalStack
USE_LOCALSTACK=true
LOCALSTACK_ENDPOINT=http://localhost:4566

# ── AWS Configuration ──────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=000000000000
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# ── Storage ────────────────────────────────────────────────────────────────
S3_BUCKET_NAME=lens-elearning-images
DYNAMODB_TABLE_NAME=lens-elearning-local

# ── Cognito ────────────────────────────────────────────────────────────────
# Local dev uses mock JWT auth — Cognito is not called.
# Set USE_MOCK_AUTH=false and fill these in for AWS deployment.
USE_MOCK_AUTH=true
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=
COGNITO_CLIENT_SECRET=

# ── External APIs (optional for local dev) ────────────────────────────────
YOUTUBE_API_KEY=
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_ENGINE_ID=

# ── Application Settings ───────────────────────────────────────────────────
JWT_SECRET_KEY=local-dev-secret-key-change-for-production
JWT_ALGORITHM=HS256
TOKEN_EXPIRE_DAYS=30

# ── Environment ────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=DEBUG
